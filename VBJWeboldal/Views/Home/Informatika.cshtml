@{
    ViewData["Title"] = "Informatika és távközlés";
}

<div class="content">

    <section class="hero hero-info">
        <div class="hero-left">
            <span class="hero-kicker">Szakmai képzés</span>

            <h2>Informatika és távközlés ágazat</h2>

            <p>
                Ha érdekel a digitális világ, a programozás
                és modern technológiák fejlesztése,
                ez az ágazat neked való.
            </p>

            <div class="hero-metrics">
                <div class="metric">
                    <b>5 év</b>
                    <span>Képzési idő</span>
                </div>
                <div class="metric">
                    <b>Szoftverfejlesztő</b>
                    <span>Végzettség</span>
                </div>
                <div class="metric">
                    <b>0012</b>
                    <span>Ágazati kód</span>
                </div>
            </div>
        </div>

        <div class="hero-right">
            <div class="hero-card">
                <div class="hero-illustration hero-illustration-info"></div>
            </div>
        </div>
    </section>

</div>