@{
    ViewData["Title"] = "Elektronika és elektrotechnika";
}

<div class="content">

    <section class="hero hero-elektro">
        <div class="hero-left">
            <span class="hero-kicker">Szakmai képzés</span>

            <h2>Elektronika és elektrotechnika ágazat</h2>

            <p>
                Ha érdekel az elektronika világa, a modern technológia
                és szeretnél biztos szakmát szerezni,
                válaszd az elektronika és elektrotechnika ágazatot!
            </p>

            <div class="hero-cta">
                <a href="#felveteli" class="hero-button">Felvételi információk</a>
            </div>

            <div class="hero-metrics">
                <div class="metric">
                    <b>5 év</b>
                    <span>Képzési idő</span>
                </div>
                <div class="metric">
                    <b>Elektronikai technikus</b>
                    <span>Végzettség</span>
                </div>
                <div class="metric">
                    <b>0011</b>
                    <span>Ágazati kód</span>
                </div>
            </div>
        </div>

        <div class="hero-right">
            <div class="hero-card">
                <div class="hero-illustration hero-illustration-elektro"></div>
            </div>
        </div>
    </section>

    <div class="grid">
        <div>

            <section class="section">
                <div class="section-h">
                    <div>
                        <h3>Mit tanulhatsz itt?</h3>
                        <p>A szakmai képzés főbb területei</p>
                    </div>
                </div>

                <div style="padding: 0 16px 16px; line-height:1.6;">
                    <ul>
                        <li>Elektronikus berendezések szerelése</li>
                        <li>Műszerek tervezése és gyártása</li>
                        <li>Méréstechnika</li>
                        <li>Villamos biztonságtechnika</li>
                        <li>Automatizálási rendszerek</li>
                    </ul>
                </div>
            </section>

            <section id="felveteli" class="section" style="margin-top:18px;">
                <div class="section-h">
                    <div>
                        <h3>Felvételi eljárás</h3>
                        <p>Pontszámítás</p>
                    </div>
                </div>

                <div style="padding: 0 16px 16px;">
                    <div class="tag">Magyar nyelv</div>
                    <div class="tag">Matematika (duplán)</div>
                    <div class="tag">Történelem</div>
                    <div class="tag">Idegen nyelv</div>

                    <p style="margin-top:12px;">
                        Maximum <b>100 pont</b> szerezhető.
                    </p>
                </div>
            </section>

        </div>

        <aside class="side">
            <div class="box">
                <div class="box-h">
                    <h4>Fontos adatok</h4>
                </div>
                <div class="box-body">
                    <div class="event">
                        <div class="date-square">5<small>év</small></div>
                        <div>
                            <b>Képzési idő</b>
                            <span>Technikumi képzés</span>
                        </div>
                    </div>
                    <div class="event">
                        <div class="date-square">0011<small>kód</small></div>
                        <div>
                            <b>Ágazati kód</b>
                            <span>Felvételinél szükséges</span>
                        </div>
                    </div>
                </div>
            </div>
        </aside>
    </div>
</div>