@{
    ViewData["Title"] = "Gépészet";
}


<div class="content">

    <section class="hero hero-gepeszet">
        <div class="hero-left">
            <span class="hero-kicker">Szakmai képzés</span>

            <h2>Gépészet ágazat</h2>

            <p>
                Ha érdekelnek a gyártási folyamatok, a CNC technológia
                és szeretnél mérnöki pályán továbbtanulni,
                akkor a gépészet neked való.
            </p>

            <div class="hero-cta">
                <a href="#felveteli" class="hero-button">Felvételi információk</a>
                <a href="#tantargyak" class="btn btn-ghost">Tantárgyak</a>
            </div>

            <div class="hero-metrics">
                <div class="metric">
                    <b>5 év</b>
                    <span>Képzési idő</span>
                </div>

                <div class="metric">
                    <b>Technikusi</b>
                    <span>Végzettség</span>
                </div>

                <div class="metric">
                    <b>Nappali</b>
                    <span>Tagozat</span>
                </div>
            </div>
        </div>

        <div class="hero-right">
            <div class="hero-card">
                <div class="hero-illustration hero-illustration-gepeszet">
                </div>
            </div>
        </div>
    </section>


    <div class="grid">

        <div>


            <section class="section">
                <div class="section-h">
                    <div>
                        <h3>Mit tanulhatsz itt?</h3>
                        <p>A szakmai képzés főbb területei</p>
                    </div>
                </div>

                <div style="padding: 0 16px 16px; line-height:1.6;">
                    <ul>
                        <li>Gyártástechnológiai alapok</li>
                        <li>CNC programozás és vezérlés</li>
                        <li>Műszaki rajz és tervezés</li>
                        <li>Gépszerkezetek működése</li>
                        <li>Méréstechnika és minőségellenőrzés</li>
                    </ul>
                </div>
            </section>


            <section id="felveteli" class="section" style="margin-top:18px;">
                <div class="section-h">
                    <div>
                        <h3>Felvételi eljárás</h3>
                        <p>Hogyan kerülhetsz be?</p>
                    </div>
                </div>

                <div style="padding: 0 16px 16px; line-height:1.6;">
                    <p>
                        A felvételi pontszám az általános iskolai eredmények
                        és a központi írásbeli vizsga alapján számítódik.
                    </p>

                    <div class="tag">Magyar nyelv</div>
                    <div class="tag">Matematika (duplán számít)</div>
                    <div class="tag">Történelem</div>
                    <div class="tag">Idegen nyelv</div>

                    <p style="margin-top:12px;">
                        Összesen maximum <b>100 pont</b> érhető el.
                    </p>
                </div>
            </section>

            <section class="section" style="margin-top:18px;">
                <div class="section-h">
                    <div>
                        <h3>Elhelyezkedési lehetőségek</h3>
                        <p>Merre vezet az út?</p>
                    </div>
                </div>

                <div style="padding: 0 16px 16px; line-height:1.6;">
                    <ul>
                        <li>Gépgyártó üzemek</li>
                        <li>Autóipar</li>
                        <li>Karbantartó mérnöki terület</li>
                        <li>Felsőoktatási továbbtanulás</li>
                    </ul>
                </div>
            </section>

        </div>


        <aside class="side">

            <div class="box">
                <div class="box-h">
                    <h4>Fontos adatok</h4>
                </div>

                <div class="box-body">
                    <div class="event">
                        <div class="date-square">
                            5
                            <small>év</small>
                        </div>
                        <div>
                            <b>Képzési idő</b>
                            <span>Technikumi képzés</span>
                        </div>
                    </div>

                    <div class="event">
                        <div class="date-square">
                            0013
                            <small>kód</small>
                        </div>
                        <div>
                            <b>Ágazati kód</b>
                            <span>Felvételinél szükséges</span>
                        </div>
                    </div>
                </div>
            </div>


            <div class="box">
                <div class="box-h">
                    <h4>Kapcsolódó dokumentumok</h4>
                </div>

                <div class="box-body">
                    <button class="linkbtn">
                        Felvételi tájékoztató
                    </button>

                    <button class="linkbtn">
                        Szakmai követelmények
                    </button>
                </div>
            </div>

        </aside>

    </div>

</div>
