@model VBJWeboldal.ViewModels.CreateUserViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Új felhasználó létrehozása";
}
<style>
    .card {
        max-width: 800px;
        margin: 0 auto;
    }
</style>
<div class="card">
    <h2>Új Tanár / Szerkesztő hozzáadása</h2>
    <form asp-action="CreateUser" method="post" enctype="multipart/form-data">
        <div asp-validation-summary="All" style="color: red; margin-bottom: 10px;"></div>

        <label>Teljes név:</label>
        <input asp-for="FullName" required />

        <label>Email cím:</label>
        <input asp-for="Email" required />

        <label>Jelszó (ideiglenes):</label>
        <input asp-for="Password" type="password" required />

        <label>Jogosultság (Szerepkör):</label>
        <select asp-for="Role" required>
            <option value="Admin">Adminisztrátor (Admin - mindent lát)</option>
            <option value="Editor">Szerkesztő (Editor - tud bejegyzést írni, de képeket nem)</option>
            <option value="GalleryManager">Galériakezelő (GalleryManager - csak a galériát kezeli)</option>
            <option value="Reader">Olvasó (Reader - csak belső dolgokat lát)</option>
        </select>
        <div class="form-group" style="margin-top: 15px;">
            <label style="font-weight: bold;">Titulus / Szaktárgy (Opcionális):</label>
            <input asp-for="Title" class="form-control" placeholder="pl. Igazgató, Matematika-Fizika szakos tanár, stb." style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;" />
        </div>

        <div class="form-group" style="margin-top: 15px; background: #f8f9fa; padding: 15px; border-radius: 8px; border: 1px solid #e9ecef;">
            <label style="cursor: pointer; font-weight: bold; margin: 0; display: flex; align-items: center; gap: 10px;">
                <input asp-for="IsManagement" style="width: 18px; height: 18px;" />
                Ez a felhasználó a VEZETŐSÉG tagja
            </label>
            <p style="font-size: 12px; color: #666; margin: 5px 0 0 28px;">(Ha be van pipálva, a Kapcsolatok oldal legtetején, kiemelve fog megjelenni.)</p>
        </div>
        <div class="form-group" style="margin-top: 15px;">
            <label style="font-weight: bold;">Profilkép (Opcionális):</label>
            <input type="file" asp-for="ProfileImage" class="form-control" accept="image/*" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; background: white;" />
            <p style="font-size: 12px; color: #666; margin-top: 5px;">(Főleg a vezetőségi tagokhoz ajánlott. Szögletes képet érdemes feltölteni, a rendszer automatikusan körbevágja.)</p>
        </div>

        <button type="submit" class="btn">Felhasználó Létrehozása</button>
        <div style="text-align: center; margin-top: 15px;">
            <a href="/Admin/Users" style="color: #555;">Mégse</a>
        </div>
    </form>
</div>