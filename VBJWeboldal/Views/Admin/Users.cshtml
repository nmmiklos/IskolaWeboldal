@model IEnumerable<VBJWeboldal.Models.ApplicationUser>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Felhasználók Kezelése";
}
<style>
    .card {
        max-width: 800px;
        margin: 0 auto;
    }
</style>
<div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h2>Regisztrált Felhasználók (Tanárok)</h2>
        <a href="/Admin/CreateUser" class="btn">+ Új Felhasználó</a>
    </div>

    <table>
        <thead>
            <tr>
                <th>Név</th>
                <th>Email</th>
                <th>Regisztráció ideje</th>
                <th>Műveletek</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td><strong>@user.FullName</strong></td>
                    <td>@user.Email</td>
                    <td>@user.CreatedAt.ToString("yyyy.MM.dd HH:mm")</td>
                    <td>
                        <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" style="display:inline;" onsubmit="return confirm('Biztosan törlöd ezt a felhasználót (@user.FullName)? Ezt a műveletet NEM lehet visszavonni!');">
                            <button type="submit" style="background:none; border:none; color:red; cursor:pointer; font-weight:bold; padding: 5px 10px; border-radius: 4px; transition: 0.2s;" onmouseover="this.style.background='rgba(220,53,69,0.1)';" onmouseout="this.style.background='none';">
                                🗑️ Törlés
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <br />
    <a href="/Admin/Index" style="color: #555;">← Vissza az Irányítópultra</a>
</div>